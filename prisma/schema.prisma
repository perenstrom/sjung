generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  // Nullable on User itself to allow bootstrapping the first/system user
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")

  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")

  createdBy User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("UserUpdatedBy", fields: [updatedById], references: [id])

  // Audit back-relations
  createdUsers              User[]               @relation("UserCreatedBy")
  updatedUsers              User[]               @relation("UserUpdatedBy")
  createdGroups             Group[]              @relation("GroupCreatedBy")
  updatedGroups             Group[]              @relation("GroupUpdatedBy")
  createdPieces             Piece[]              @relation("PieceCreatedBy")
  updatedPieces             Piece[]              @relation("PieceUpdatedBy")
  createdFiles              File[]               @relation("FileCreatedBy")
  updatedFiles              File[]               @relation("FileUpdatedBy")
  createdPeople             Person[]             @relation("PersonCreatedBy")
  updatedPeople             Person[]             @relation("PersonUpdatedBy")
  createdLinks              Link[]               @relation("LinkCreatedBy")
  updatedLinks              Link[]               @relation("LinkUpdatedBy")
  createdSetLists           SetList[]            @relation("SetListCreatedBy")
  updatedSetLists           SetList[]            @relation("SetListUpdatedBy")
  createdSetListPieces      SetListPiece[]       @relation("SetListPieceCreatedBy")
  updatedSetListPieces      SetListPiece[]       @relation("SetListPieceUpdatedBy")
  groups UsersToGroups[]

  @@map("users")
}

model Group {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  name String
  slug String @unique @map("slug")

  createdBy User @relation("GroupCreatedBy", fields: [createdById], references: [id])
  updatedBy User @relation("GroupUpdatedBy", fields: [updatedById], references: [id])

  users  UsersToGroups[]
  pieces Piece[]
  people Person[]
  setLists SetList[]

  @@map("groups")
}

model UsersToGroups {
  userId  String @map("user_id")
  groupId String @map("group_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("users_to_groups")
}

model Piece {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  name    String
  groupId String @map("group_id")

  createdBy User          @relation("PieceCreatedBy", fields: [createdById], references: [id])
  updatedBy User          @relation("PieceUpdatedBy", fields: [updatedById], references: [id])
  group     Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  files     File[]
  credits   PersonToPiece[]
  links     Link[]
  setListEntries SetListPiece[]

  @@map("pieces")
}

model Link {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  url   String
  label String?

  pieceId String @map("piece_id")

  createdBy User  @relation("LinkCreatedBy", fields: [createdById], references: [id])
  updatedBy User  @relation("LinkUpdatedBy", fields: [updatedById], references: [id])
  piece     Piece @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@map("links")
}

model File {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  displayName String @map("display_name")
  fileName    String @map("file_name")
  storagePath String @map("storage_path")
  mimeType    String @map("mime_type")
  size        Int

  pieceId   String @map("piece_id")
  createdBy User   @relation("FileCreatedBy", fields: [createdById], references: [id])
  updatedBy User   @relation("FileUpdatedBy", fields: [updatedById], references: [id])
  piece     Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@map("files")
}

model Person {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  name    String
  groupId String @map("group_id")

  createdBy User            @relation("PersonCreatedBy", fields: [createdById], references: [id])
  updatedBy User            @relation("PersonUpdatedBy", fields: [updatedById], references: [id])
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  credits   PersonToPiece[]

  @@map("people")
}

model PersonToPiece {
  personId String @map("person_id")
  pieceId  String @map("piece_id")
  role     String

  person Person @relation(fields: [personId], references: [id], onDelete: Restrict)
  piece  Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@id([personId, pieceId, role])
  @@map("people_to_pieces")
}

model SetList {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  name    String
  date    DateTime?
  groupId String @map("group_id")

  createdBy User  @relation("SetListCreatedBy", fields: [createdById], references: [id])
  updatedBy User  @relation("SetListUpdatedBy", fields: [updatedById], references: [id])
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  pieces    SetListPiece[]

  @@map("set_lists")
}

model SetListPiece {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String   @map("updated_by_id")

  setListId String @map("set_list_id")
  pieceId   String @map("piece_id")
  position  Int?

  createdBy User    @relation("SetListPieceCreatedBy", fields: [createdById], references: [id])
  updatedBy User    @relation("SetListPieceUpdatedBy", fields: [updatedById], references: [id])
  setList   SetList @relation(fields: [setListId], references: [id], onDelete: Cascade)
  piece     Piece   @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@map("set_list_pieces")
}
